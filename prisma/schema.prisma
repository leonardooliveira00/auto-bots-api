// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id Int @id @default(autoincrement())
  name String
  lastname String
  email String @unique
  phoneNumber String
  passwordHash String

  cpfHash String @unique
  cpfEncrypted String

  address Address?
  addressId Int? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address{
  id Int @id @default(autoincrement())
  street String
  number String
  complement String?
  city String
  state String
  postalCode String

  userId Int @unique
  user User @relation(fields: [userId], references: [id])
}